# ============================================================================
# Alif24 Platform - Environment Variables
# Copy this file to .env and fill in real values:  cp .env.example .env
# NEVER commit .env to git!
# ============================================================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=alif24
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# JWT Auth
JWT_SECRET=CHANGE_ME_generate_64_char_random_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_char_random_string

# OpenAI
OPENAI_API_KEY=sk-proj-CHANGE_ME

# Azure OpenAI
AZURE_OPENAI_KEY=CHANGE_ME
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-chat
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure Speech
AZURE_SPEECH_KEY=CHANGE_ME
AZURE_SPEECH_REGION=westeurope

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=CHANGE_ME
AZURE_CONTAINER_NAME=audiostories

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME

# Admin
ADMIN_SECRET_KEY=CHANGE_ME_strong_admin_key

# Redis
REDIS_URL=redis://redis:6379

# CORS (comma separated, empty = allow all)
CORS_ORIGINS=

# pgAdmin (remove in production!)
PGADMIN_EMAIL=admin@alif24.uz
PGADMIN_PASSWORD=CHANGE_ME

# ============================================================================
# Google OAuth2 — "Sign in with Google"
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create OAuth Client ID → Web application
# 3. Authorized redirect URIs must include:
#      https://alif24.uz/api/v1/auth/google/callback
#      http://localhost:8000/api/v1/auth/google/callback   (dev only)
# ============================================================================
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://alif24.uz/api/v1/auth/google/callback
OAUTH_SUCCESS_REDIRECT=https://alif24.uz/
OAUTH_FAILURE_REDIRECT=https://alif24.uz/login?oauth_error=1
# Used by starlette SessionMiddleware for the short-lived OAuth state cookie.
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET_KEY=CHANGE_ME_generate_64_char_random_string

# ============================================================================
# Transactional email — Gmail SMTP (fastapi-mail)
# 1. myaccount.google.com/security → enable 2-Step Verification
# 2. Same page → "App passwords" → create one for "Mail" → "Other"
# 3. Paste the 16-char password below (no spaces)
# Leave MAIL_ENABLED=false to keep emails as no-ops in dev.
# ============================================================================
MAIL_ENABLED=false
MAIL_USERNAME=info@alif24.uz
MAIL_PASSWORD=CHANGE_ME_16_char_app_password
MAIL_FROM=info@alif24.uz
MAIL_FROM_NAME=Alif24
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
# Broadcast throttling (Gmail cap: 500/day free, 2000/day Workspace)
MAIL_BROADCAST_BATCH_SIZE=50
MAIL_BROADCAST_SLEEP_SECONDS=2.0
